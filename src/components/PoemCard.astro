---
interface Props {
	slug: string;
	title: string;
	sadr: string;
	ajz: string;
	category?: string;
	'data-title'?: string;
	'data-verse'?: string;
}

const { slug, title, sadr, ajz, category, 'data-title': dataTitle, 'data-verse': dataVerse } = Astro.props;
---

<a
	href={`/poem/${slug}`}
	class="poem-card"
	data-title={dataTitle}
	data-verse={dataVerse}
>
	<h3 class="poem-title">{title}</h3>
	{category && <span class="poem-category">{category}</span>}

	<p class="poem-excerpt">
		{sadr}  ❊  {ajz}
	</p>

	<span class="read-more">اقرأ المزيد</span>
</a>

<style>
	.poem-card {
		display: flex;
		flex-direction: column;
		border: 1px solid #e0ddd8;
		border-radius: 4px;
		padding: 2.5rem 2rem;
		background-color: #fafaf7;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s ease;
		cursor: pointer;
	}

	.poem-card:hover {
		border-color: #7a2532;
	}

	.poem-title {
		font-family: 'Amiri', serif;
		font-size: 1.5rem;
		font-weight: 700;
		color: #2c2925;
		margin: 0 0 0.5rem;
	}

	.poem-category {
		font-family: 'IBM Plex Sans Arabic', sans-serif;
		font-size: 0.8rem;
		font-weight: 500;
		color: #6b6560;
		display: inline-block;
		margin-bottom: 1.5rem;
	}

	.poem-excerpt {
		font-family: 'Amiri', serif;
		font-size: 1rem;
		font-style: italic;
		line-height: 2.4;
		color: #2c2925;
		margin: 0 0 1.5rem;
		flex: 1;
		text-align: center;
	}

	.read-more {
		font-family: 'IBM Plex Sans Arabic', sans-serif;
		font-size: 0.9rem;
		font-weight: 500;
		color: #7a2532;
		text-decoration: none;
		display: inline-block;
		margin-top: auto;
	}

	@media (max-width: 480px) {
		.poem-card {
			padding: 1.75rem 1.25rem;
		}
	}
</style>
