---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PoemCard from '../../components/PoemCard.astro';
import { poems, categories, type Poem } from '../../data/poems';
import { toArabicDigits } from '../../lib/utils';

export function getStaticPaths() {
	return Object.keys(categories).map(slug => ({
		params: { slug },
		props: {
			categoryName: categories[slug],
			categoryPoems: poems.filter(p => p.category === slug),
		},
	}));
}

interface Props {
	categoryName: string;
	categoryPoems: Poem[];
}

const { categoryName, categoryPoems } = Astro.props;
---

<Layout
	title={`قصائد ${categoryName} — من ديوان الشاعر سمير الشيخ حسين`}
	description={`تصفَّح واقرأ ${toArabicDigits(categoryPoems.length)} قصيدة في باب ${categoryName} من ديوان الشاعر سمير الشيخ حسين — أكثر من ٣٠٠ قصيدة عربية أصيلة في الغزل والحكمة والوطنيات والرثاء`}
>
	<div class="page">
		<Header />

		<!-- Category Hero -->
		<section class="category-hero">
			<nav class="breadcrumb" aria-label="مسار التنقل">
				<a href="/">الرئيسية</a>
				<span class="sep" aria-hidden="true">/</span>
				<span class="current" aria-current="page">{categoryName}</span>
			</nav>
			<div class="rule"></div>
			<h1 class="category-title">{categoryName}</h1>
			<p class="category-count">{toArabicDigits(categoryPoems.length)} قصيدة</p>
			<div class="rule"></div>
		</section>

		<!-- Poems Section -->
		<main id="main-content" class="poems-section">
			<div class="section-container">
				<!-- Search -->
				<div class="search-bar">
					<svg class="search-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="11" cy="11" r="8"/>
						<line x1="21" y1="21" x2="16.65" y2="16.65"/>
					</svg>
					<label for="search-input" class="sr-only">ابحث بعنوان القصيدة أو مطلعها</label>
					<input
						type="search"
						id="search-input"
						class="search-input"
						placeholder="ابحث بعنوان القصيدة أو مطلعها..."
						autocomplete="off"
					/>
				</div>

				<h2 class="sr-only">القصائد</h2>
				<div class="poems-grid" id="poems-grid">
					{categoryPoems.map(poem => (
						<PoemCard
							slug={poem.slug}
							title={poem.title}
							sadr={poem.verses[0].sadr}
							ajz={poem.verses[0].ajz}
							data-title={poem.title}
							data-verse={`${poem.verses[0].sadr} ${poem.verses[0].ajz}`}
						/>
					))}
				</div>

				<p class="no-results" id="no-results">لا توجد نتائج</p>

				<nav class="bottom-nav" aria-label="العودة">
					<a href="/" class="back-link">
						<span class="arrow" aria-hidden="true">&rarr;</span>
						العودة إلى الرئيسية
					</a>
				</nav>
			</div>
		</main>

		<Footer />
	</div>
</Layout>

<script>
	const input = document.getElementById('search-input') as HTMLInputElement | null;
	const grid = document.getElementById('poems-grid');
	const noResults = document.getElementById('no-results');
	if (!input || !grid) throw new Error('Missing search elements');
	const cards = grid.querySelectorAll('.poem-card');

	input.addEventListener('input', () => {
		const q = input.value.trim();
		let visible = 0;

		cards.forEach(card => {
			const el = card as HTMLElement;
			const title = el.dataset.title || '';
			const verse = el.dataset.verse || '';
			const match = !q || title.includes(q) || verse.includes(q);
			el.style.display = match ? '' : 'none';
			if (match) visible++;
		});

		if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
	});
</script>

<style>
	/* ---------- Category Hero ---------- */

	.category-hero {
		text-align: center;
		padding: 4rem 2rem 3rem;
		background-color: #fafaf7;
	}

	.breadcrumb {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: #6b6560;
		margin-bottom: 2.5rem;
	}

	.breadcrumb a {
		color: #6b6560;
		text-decoration: none;
		transition: color 0.2s;
		min-height: 44px;
		display: inline-flex;
		align-items: center;
	}

	.breadcrumb a:hover { color: #7a2532; }

	.breadcrumb .sep {
		opacity: 0.4;
		font-size: 0.75rem;
	}

	.breadcrumb .current {
		color: #2c2925;
		font-weight: 500;
	}

	.category-title {
		font-family: 'Amiri', serif;
		font-size: 2.8rem;
		font-weight: 700;
		color: #2c2925;
		margin: 1.5rem 0 0.5rem;
		line-height: 1.2;
	}

	.category-count {
		font-family: 'IBM Plex Sans Arabic', sans-serif;
		font-size: 1rem;
		font-weight: 300;
		color: #6b6560;
		margin: 0 0 2rem;
		letter-spacing: 0.02em;
	}

	/* ---------- Search Bar ---------- */

	.search-bar {
		position: relative;
		max-width: 480px;
		margin: 0 auto 3rem;
	}

	.search-icon {
		position: absolute;
		right: 1.25rem;
		top: 50%;
		transform: translateY(-50%);
		color: #b5b0a8;
		pointer-events: none;
		transition: color 0.2s;
	}

	.search-bar:focus-within .search-icon {
		color: #7a2532;
	}

	.search-input {
		width: 100%;
		font-family: 'IBM Plex Sans Arabic', sans-serif;
		font-size: 0.9rem;
		font-weight: 400;
		padding: 0.85rem 3rem 0.85rem 1.25rem;
		border: 1px solid #e0ddd8;
		border-radius: 4px;
		background: #fafaf7;
		color: #2c2925;
		transition: border-color 0.2s, box-shadow 0.2s;
		box-sizing: border-box;
	}

	.search-input::placeholder {
		color: #b5b0a8;
		font-weight: 300;
	}

	.search-input:focus {
		border-color: #7a2532;
		box-shadow: 0 0 0 3px rgba(122, 37, 50, 0.06);
		outline: 2px solid #7a2532;
		outline-offset: 1px;
	}

	.no-results {
		display: none;
		text-align: center;
		font-family: 'Amiri', serif;
		font-size: 1.1rem;
		color: #6b6560;
		margin: 4rem 0;
	}

	/* ---------- Bottom Nav ---------- */

	.bottom-nav {
		margin-top: 3rem;
		text-align: center;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: 'IBM Plex Sans Arabic', sans-serif;
		font-size: 0.95rem;
		font-weight: 500;
		color: #7a2532;
		text-decoration: none;
		min-height: 44px;
		transition: gap 0.2s ease;
	}

	.back-link:hover {
		gap: 0.75rem;
	}

	/* ---------- Responsive ---------- */

	@media (max-width: 768px) {
		.category-hero {
			padding: 3rem 1.5rem 2rem;
		}

		.category-title {
			font-size: 2.2rem;
		}
	}

	@media (max-width: 480px) {
		.category-hero {
			padding: 2rem 1rem 1.5rem;
		}

		.category-title {
			font-size: 1.8rem;
		}

		.breadcrumb {
			margin-bottom: 1.5rem;
		}

		.search-bar {
			margin-bottom: 2rem;
		}
	}
</style>
