---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
	title="سياسة الخصوصية — ديوان الشاعر سمير الشيخ حسين"
	description="سياسة الخصوصية لموقع ديوان الشاعر سمير الشيخ حسين — نحترم خصوصيتكم ولا نجمع أي بيانات شخصية ولا نستخدم ملفات تعريف الارتباط لأغراض التتبع"
>
	<div class="page">
		<Header />

		<main id="main-content" class="content-page">
			<div class="content-container">
				<div class="rule"></div>
				<h1 class="page-title">سياسة الخصوصية</h1>

				<div class="legal-content">
					<h2>جمع البيانات</h2>
					<p>لا يجمع هذا الموقع أي بيانات شخصية من الزوار. لا نستخدم ملفات تعريف الارتباط (cookies) لأغراض التتبع، ولا نطلب تسجيل الدخول أو إنشاء حسابات.</p>

					<h2>محتوى الموقع</h2>
					<p>جميع القصائد المنشورة على هذا الموقع هي من تأليف الشاعر سمير الشيخ حسين. جميع الحقوق محفوظة ولا يجوز إعادة نشر المحتوى دون إذن مسبق.</p>

					<h2>الروابط الخارجية</h2>
					<p>لا يتضمن هذا الموقع روابط خارجية. في حال إضافة روابط مستقبلاً، فإننا لا نتحمل مسؤولية محتوى المواقع الخارجية.</p>

					<h2>تواصل معنا</h2>
					<p>لأي استفسار حول سياسة الخصوصية، يُرجى <a href="/contact">التواصل معنا</a>.</p>
				</div>

				<nav class="bottom-nav" aria-label="العودة">
					<a href="/" class="back-link">
						<span class="arrow" aria-hidden="true">&rarr;</span>
						العودة إلى الرئيسية
					</a>
				</nav>
			</div>
		</main>

		<Footer />
	</div>
</Layout>

<style>
	.content-page {
		padding: 4rem 2rem 6rem;
		background-color: #fafaf7;
	}

	.content-container {
		max-width: 700px;
		margin: 0 auto;
	}

	.page-title {
		font-family: 'Amiri', serif;
		font-size: 2.8rem;
		font-weight: 700;
		color: #2c2925;
		text-align: center;
		margin: 1.5rem 0 3rem;
		line-height: 1.2;
	}

	.legal-content h2 {
		font-family: 'Amiri', serif;
		font-size: 1.5rem;
		font-weight: 700;
		color: #2c2925;
		margin: 2.5rem 0 1rem;
	}

	.legal-content h2:first-child {
		margin-top: 0;
	}

	.legal-content p {
		font-family: 'IBM Plex Sans Arabic', sans-serif;
		font-size: 1.05rem;
		line-height: 2.2;
		color: #2c2925;
		text-align: justify;
		margin-bottom: 1rem;
	}

	.legal-content a {
		color: #7a2532;
		text-decoration: none;
		border-bottom: 1px solid #e0ddd8;
		transition: border-color 0.2s;
	}

	.legal-content a:hover {
		border-color: #7a2532;
	}

	.bottom-nav {
		margin-top: 3rem;
		text-align: center;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: 'IBM Plex Sans Arabic', sans-serif;
		font-size: 0.95rem;
		font-weight: 500;
		color: #7a2532;
		text-decoration: none;
		min-height: 44px;
		transition: gap 0.2s ease;
	}

	.back-link:hover {
		gap: 0.75rem;
	}

	@media (max-width: 768px) {
		.content-page {
			padding: 3rem 1.5rem 4rem;
		}

		.page-title {
			font-size: 2.2rem;
		}
	}

	@media (max-width: 480px) {
		.content-page {
			padding: 2rem 1rem 3rem;
		}

		.page-title {
			font-size: 1.8rem;
		}

		.legal-content p {
			text-align: right;
		}
	}
</style>
