---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { poems, categories, type Poem } from '../../data/poems';
import { toArabicDigits } from '../../lib/utils';

export function getStaticPaths() {
	return poems.map((poem, i) => ({
		params: { slug: poem.slug },
		props: { poem, nextPoem: poems[(i + 1) % poems.length] },
	}));
}

interface Props {
	poem: Poem;
	nextPoem: Poem;
}

const { poem, nextPoem } = Astro.props;
const categoryName = categories[poem.category] ?? poem.category;
const verse = `${poem.verses[0].sadr} ❊ ${poem.verses[0].ajz}`;
const suffix = ' — من ديوان الشاعر سمير الشيخ حسين';
const padding = ' — أكثر من ٣٠٠ قصيدة عربية أصيلة على بحور الخليل بن أحمد';
const base = `قصيدة ${poem.title} من باب ${categoryName} — ${verse}`;
const full = base + suffix;
const withPadding = base + padding;
const poemDescription = full.length <= 160
	? (full.length < 120 ? (full + padding).slice(0, 160) : full)
	: base.length >= 120 && base.length <= 160
		? base
		: withPadding.length <= 160
			? withPadding
			: withPadding.slice(0, 157) + '...';
---

<Layout
	title={`${poem.title} — سمير الشيخ حسين | ديوان شعر`}
	description={poemDescription}
	ogType="article"
>
	<div class="page" data-poem-slug={poem.slug} data-poem-title={poem.title} data-first-sadr={poem.verses[0].sadr} data-first-ajz={poem.verses[0].ajz}>
		<Header />

		<!-- Poem Page -->
		<main id="main-content" class="poem-page">
			<!-- Breadcrumb -->
			<nav class="breadcrumb" aria-label="مسار التنقل">
				<a href="/">الرئيسية</a>
				<span class="sep" aria-hidden="true">/</span>
				<a href="/#poems">الديوان</a>
				<span class="sep" aria-hidden="true">/</span>
				<span class="current" aria-current="page">{poem.title}</span>
			</nav>

			<!-- Poem Header -->
			<header class="poem-header">
				<div class="rule"></div>
				<h1 class="poem-title">{poem.title}</h1>

				<div class="poem-meta">
					<span class="meta-item">
						<span class="meta-label">الباب:</span>
						<a href={`/category/${poem.category}`} class="meta-tag">{categories[poem.category]}</a>
					</span>
					{poem.date && (
						<>
							<span class="meta-divider"></span>
							<span class="meta-item">
								<span class="meta-label">التاريخ:</span>
								{new Date(poem.date).toLocaleDateString('ar-SA', { year: 'numeric', month: 'long', day: 'numeric' })}
							</span>
						</>
					)}
				</div>

				<div class="rule"></div>
			</header>

			<!-- Toolbar -->
			<div class="toolbar-wrap no-print">
				<div class="toolbar-buttons">
					<button
						class="toolbar-circle-btn"
						id="font-toggle"
						aria-expanded="false"
						aria-controls="font-controls"
						aria-label="إعدادات الخط"
					>
						<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M17 3a2.828 2.828 0 114 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
							<path d="M15 5l4 4"/>
						</svg>
					</button>
					<button
						class="toolbar-circle-btn"
						id="share-toggle"
						aria-expanded="false"
						aria-controls="share-controls"
						aria-label="مشاركة القصيدة"
					>
						<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="18" cy="5" r="3"/>
							<circle cx="6" cy="12" r="3"/>
							<circle cx="18" cy="19" r="3"/>
							<line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
							<line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
						</svg>
					</button>
				</div>

				<div id="font-controls" class="font-controls">
					<div class="font-controls-inner">
						<div class="size-buttons">
							<button id="font-increase" class="size-btn"><span aria-hidden="true">&plus;</span><span class="sr-only">تكبير الخط</span></button>
							<button id="font-decrease" class="size-btn"><span aria-hidden="true">&minus;</span><span class="sr-only">تصغير الخط</span></button>
						</div>
						<div class="font-choices">
							<button class="font-choice font-choice-active" data-font="'Amiri', serif" data-index="0" aria-pressed="true">
								<span class="font-choice-name">الأميري</span>
								<span class="font-choice-sample">نسخ كلاسيكي</span>
							</button>
							<button class="font-choice" data-font="'Noto Naskh Arabic', serif" data-index="1" aria-pressed="false">
								<span class="font-choice-name">النسخ</span>
								<span class="font-choice-sample">نسخ عصري</span>
							</button>
							<button class="font-choice" data-font="'Aref Ruqaa', serif" data-index="2" aria-pressed="false">
								<span class="font-choice-name">الرقعة</span>
								<span class="font-choice-sample">خط الرقعة</span>
							</button>
							<button class="font-choice" data-font="'Cairo', sans-serif" data-index="3" aria-pressed="false">
								<span class="font-choice-name">القاهرة</span>
								<span class="font-choice-sample">خط عصري</span>
							</button>
						</div>
					</div>
				</div>

				<div id="share-controls" class="font-controls">
					<div class="font-controls-inner" role="group" aria-label="مشاركة القصيدة">
						<button class="share-btn" data-share="whatsapp" aria-label="مشاركة عبر واتساب">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
							</svg>
						</button>
						<button class="share-btn" data-share="telegram" aria-label="مشاركة عبر تيليجرام">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
								<path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
							</svg>
						</button>
						<button class="share-btn" data-share="x" aria-label="مشاركة عبر إكس">
							<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
							</svg>
						</button>
						<button class="share-btn" data-share="facebook" aria-label="مشاركة عبر فيسبوك">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
								<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
							</svg>
						</button>
						<button class="share-btn" data-share="email" aria-label="مشاركة عبر البريد الإلكتروني">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
								<rect x="2" y="4" width="20" height="16" rx="2"/>
								<path d="M22 4L12 13 2 4"/>
							</svg>
						</button>
						<button class="share-btn" id="copy-link-btn" data-share="copy" aria-label="نسخ الرابط">
							<svg class="icon-link" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
								<path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
								<path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
							</svg>
							<svg class="icon-check" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none">
								<polyline points="20 6 9 17 4 12"/>
							</svg>
						</button>
					</div>
				</div>
			</div>

			<!-- Poem Body -->
			<article class:list={['poem-body', { 'poem-body--free': poem.freeVerse }]}>
				{poem.verses.map((verse, i) => (
					<div
						id={`verse-${i}`}
						class:list={['verse-row', { 'verse-row--free': poem.freeVerse }]}
						data-index={i}
						role="button"
						tabindex="0"
						title={`البيت ${toArabicDigits(i + 1)} — اضغط لتعليم موضع القراءة`}
					>
						<span class="verse-number">{toArabicDigits(i + 1)}</span>
						{poem.freeVerse ? (
							<span class="free-line">{verse.sadr}</span>
						) : (
							<>
								<span class="sadr">{verse.sadr}</span>
								<span class="verse-divider" aria-hidden="true"></span>
								<span class="ajz">{verse.ajz}</span>
							</>
						)}
					</div>
				))}
			</article>

			<hr class="poem-end-rule" />

			<!-- Navigation -->
			<nav class="poem-nav no-print" aria-label="التنقل بين القصائد">
				<a href="/" class="back-link">
					<span class="arrow" aria-hidden="true">&rarr;</span>
					العودة إلى الديوان
				</a>
				<a href={`/poem/${nextPoem.slug}`} class="nav-link-btn">
					{nextPoem.title}
					<span class="arrow" aria-hidden="true">&larr;</span>
				</a>
			</nav>
		</main>

		<Footer />
	</div>
</Layout>

<script>
	// Read poem data from DOM attributes instead of define:vars
	const pageEl = document.querySelector('.page') as HTMLElement;
	const poemSlug = pageEl.dataset.poemSlug!;
	const poemTitle = pageEl.dataset.poemTitle!;
	const firstSadr = pageEl.dataset.firstSadr!;
	const firstAjz = pageEl.dataset.firstAjz!;

	// Font size control
	const fontSizes = [
		{ verse: '1.05rem', lineHeight: '2.2' },
		{ verse: '1.25rem', lineHeight: '2.4' },
		{ verse: '1.5rem',  lineHeight: '2.6' },
		{ verse: '1.75rem', lineHeight: '2.8' },
	];
	let fontSizeLevel = 1;

	const fontToggle = document.getElementById('font-toggle');
	const shareToggle = document.getElementById('share-toggle');
	const fontControls = document.getElementById('font-controls');
	const shareControls = document.getElementById('share-controls');
	const increaseBtn = document.getElementById('font-increase');
	const decreaseBtn = document.getElementById('font-decrease');
	const verseRows = document.querySelectorAll('.verse-row');

	// Toggle panels
	fontToggle?.addEventListener('click', () => {
		const open = fontControls?.classList.toggle('font-controls-open');
		fontToggle.classList.toggle('toolbar-circle-open', open);
		fontToggle.setAttribute('aria-expanded', String(open));
		shareControls?.classList.remove('font-controls-open');
		shareToggle?.classList.remove('toolbar-circle-open');
		shareToggle?.setAttribute('aria-expanded', 'false');
	});

	shareToggle?.addEventListener('click', () => {
		const open = shareControls?.classList.toggle('font-controls-open');
		shareToggle.classList.toggle('toolbar-circle-open', open);
		shareToggle.setAttribute('aria-expanded', String(open));
		fontControls?.classList.remove('font-controls-open');
		fontToggle?.classList.remove('toolbar-circle-open');
		fontToggle?.setAttribute('aria-expanded', 'false');
	});

	// Font size
	function applyFontSize() {
		const size = fontSizes[fontSizeLevel];
		verseRows.forEach(row => {
			(row as HTMLElement).style.fontSize = size.verse;
			(row as HTMLElement).style.lineHeight = size.lineHeight;
		});
		if (increaseBtn) (increaseBtn as HTMLButtonElement).disabled = fontSizeLevel === 3;
		if (decreaseBtn) (decreaseBtn as HTMLButtonElement).disabled = fontSizeLevel === 0;
	}

	increaseBtn?.addEventListener('click', () => {
		if (fontSizeLevel < 3) { fontSizeLevel++; applyFontSize(); }
	});

	decreaseBtn?.addEventListener('click', () => {
		if (fontSizeLevel > 0) { fontSizeLevel--; applyFontSize(); }
	});

	// Font family
	document.querySelectorAll('.font-choice').forEach(btn => {
		btn.addEventListener('click', () => {
			document.querySelectorAll('.font-choice').forEach(b => {
				b.classList.remove('font-choice-active');
				b.setAttribute('aria-pressed', 'false');
			});
			btn.classList.add('font-choice-active');
			btn.setAttribute('aria-pressed', 'true');
			const font = (btn as HTMLElement).dataset.font;
			verseRows.forEach(row => { (row as HTMLElement).style.fontFamily = font!; });
		});
	});

	// Bookmark
	const bookmarkKey = `bookmark-${poemSlug}`;
	let bookmarkedLine: number | null = null;
	const saved = localStorage.getItem(bookmarkKey);
	if (saved !== null) {
		bookmarkedLine = parseInt(saved, 10);
		const el = document.getElementById(`verse-${bookmarkedLine}`);
		if (el) {
			el.classList.add('verse-bookmarked');
			setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'center' }), 300);
		}
	}

	verseRows.forEach(row => {
		const handler = () => {
			const index = parseInt((row as HTMLElement).dataset.index!, 10);
			document.querySelectorAll('.verse-bookmarked').forEach(el => el.classList.remove('verse-bookmarked'));

			if (bookmarkedLine === index) {
				bookmarkedLine = null;
				localStorage.removeItem(bookmarkKey);
			} else {
				bookmarkedLine = index;
				localStorage.setItem(bookmarkKey, String(index));
				row.classList.add('verse-bookmarked');
			}
		};
		row.addEventListener('click', handler);
		row.addEventListener('keydown', (e) => {
			if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') { e.preventDefault(); handler(); }
		});
	});

	// Share
	const shareText = `${poemTitle} — سمير الشيخ حسين\n\n${firstSadr}    ${firstAjz}`;
	const shareUrl = window.location.href;

	document.querySelectorAll('.share-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const type = (btn as HTMLElement).dataset.share;
			switch (type) {
				case 'whatsapp':
					window.open(`https://wa.me/?text=${encodeURIComponent(shareText + '\n\n' + shareUrl)}`, '_blank', 'noopener,noreferrer');
					break;
				case 'telegram':
					window.open(`https://t.me/share/url?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareText)}`, '_blank', 'noopener,noreferrer');
					break;
				case 'x':
					window.open(`https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`, '_blank', 'noopener,noreferrer');
					break;
				case 'facebook':
					window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`, '_blank', 'noopener,noreferrer');
					break;
				case 'email':
					window.location.href = `mailto:?subject=${encodeURIComponent(poemTitle + ' — سمير الشيخ')}&body=${encodeURIComponent(shareText + '\n\n' + shareUrl)}`;
					break;
				case 'copy': {
					const copyBtn = document.getElementById('copy-link-btn');
					const iconLink = copyBtn?.querySelector('.icon-link') as HTMLElement | null;
					const iconCheck = copyBtn?.querySelector('.icon-check') as HTMLElement | null;
					navigator.clipboard.writeText(shareUrl).then(() => {
						if (iconLink) iconLink.style.display = 'none';
						if (iconCheck) iconCheck.style.display = 'block';
						setTimeout(() => {
							if (iconLink) iconLink.style.display = 'block';
							if (iconCheck) iconCheck.style.display = 'none';
						}, 2000);
					});
					break;
				}
			}
		});
	});
</script>

<style>
	/* ============================================
	   Full Poem Page - Minimalist Style
	   ============================================ */

	.page {
		zoom: 1.25;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	/* ---------- Poem Page ---------- */

	.poem-page {
		flex: 1;
		max-width: 900px;
		width: 100%;
		margin: 0 auto;
		padding: 2rem 2rem 4rem;
	}

	/* ---------- Breadcrumb ---------- */

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: #6b6560;
		margin-bottom: 3rem;
		padding-top: 1rem;
	}

	.breadcrumb a {
		color: #6b6560;
		text-decoration: none;
		transition: color 0.2s;
		min-height: 44px;
		display: inline-flex;
		align-items: center;
	}

	.breadcrumb a:hover { color: #7a2532; }

	.breadcrumb .sep {
		opacity: 0.4;
		font-size: 0.75rem;
	}

	.breadcrumb .current {
		color: #2c2925;
		font-weight: 500;
	}

	/* ---------- Poem Header ---------- */

	.poem-header {
		text-align: center;
		margin-bottom: 2rem;
	}

	.poem-title {
		font-family: 'Amiri', serif;
		font-size: 2.4rem;
		font-weight: 700;
		color: #2c2925;
		margin: 2rem 0 1.5rem;
		line-height: 1.3;
	}

	.poem-meta {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.25rem;
		font-size: 0.9rem;
		color: #6b6560;
		margin-bottom: 2rem;
		flex-wrap: wrap;
	}

	.meta-label {
		font-weight: 500;
		color: #2c2925;
	}

	.meta-divider {
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background-color: #d0cdc8;
	}

	.meta-tag {
		color: #7a2532;
		font-weight: 500;
		text-decoration: none;
		transition: opacity 0.2s;
	}

	.meta-tag:hover {
		opacity: 0.7;
	}

	/* ---------- Toolbar ---------- */

	.toolbar-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-bottom: 2.5rem;
	}

	.toolbar-buttons {
		display: flex;
		gap: 0.75rem;
	}

	.toolbar-circle-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border: 1px solid #d0cdc8;
		border-radius: 50%;
		background: #fafaf7;
		color: #6b6560;
		cursor: pointer;
		transition: border-color 0.2s, color 0.2s, background-color 0.2s;
	}

	.toolbar-circle-btn:hover,
	.toolbar-circle-btn:global(.toolbar-circle-open) {
		border-color: #7a2532;
		color: #7a2532;
		background-color: rgba(122, 37, 50, 0.04);
	}

	/* ---------- Collapsible Controls ---------- */

	.font-controls {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.3s ease;
		overflow: hidden;
	}

	.font-controls:global(.font-controls-open) {
		grid-template-rows: 1fr;
	}

	.font-controls-inner {
		min-height: 0;
